# ── ML tracking run data ──────────────────────────────────────────
# These are generated locally when you run experiments.
# Viewers should run the notebooks themselves to produce their own.
mlruns/
wandb/
artifacts/
model_dir/

# ── Pipeline output files ─────────────────────────────────────────
# Generated by running the notebooks/scripts — not source files.
out/

# ── Trained model binaries ───────────────────────────────────────
# Generated artefacts. Regenerate by running the demo.
*.pth
*.pt
*.pkl
*.ckpt
*.joblib
*.onnx
*.onnx.data

# ── Raw/intermediate data files ──────────────────────────────────
# Large or generated data that doesn't belong in git.
data.csv
*.parquet
cali_house_raw.csv
raw_sales_data.csv
random_forest_model.joblib

# ── DVC ──────────────────────────────────────────────────────────
# DVC manages its own data — source data lives in the DVC remote.
# The .dvc pointer files ARE committed (they're small text files).

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
