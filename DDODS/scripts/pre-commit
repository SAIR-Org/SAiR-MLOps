#!/bin/sh
# Pre-commit hook: strip outputs from any .ipynb files being committed.
# Install: make install-hook  (copies this to .git/hooks/pre-commit)

STAGED_NOTEBOOKS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ipynb$')

if [ -z "$STAGED_NOTEBOOKS" ]; then
    exit 0
fi

echo "Stripping notebook outputs before commit..."

for NB in $STAGED_NOTEBOOKS; do
    if [ -f "$NB" ]; then
        uv run --no-sync python scripts/strip_notebooks.py "$NB"
        git add "$NB"
    fi
done

echo "Notebooks cleaned and re-staged."
